generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model answers {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username String?
  game_id  String? @db.Uuid
  answers  String?
}

model game {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomCode   String?
  mostRecent String?
}
